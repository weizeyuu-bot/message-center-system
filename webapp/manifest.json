{
  "_version": "1.12.0",
  "sap.app": {
    "id": "myapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "sourceTemplate": {
      "id": "ui5template.basicSAPUI5ApplicationProject",
      "version": "1.40.12"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "rootView": {
      "viewName": "myapp.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    },
    "dependencies": {
      "minUI5Version": "1.65.6",
      "libs": {
        "sap.ui.layout": {},
        "sap.ui.core": {},
        "sap.m": {},
        "sap.ui.unified": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "myapp.i18n.i18n",
          "supportedLocales": ["en", ""],
          "fallbackLocale": ""
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "myapp.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": true
      },
      "routes": [
        {
          "name": "RouteApp",
          "pattern": "",
          "target": [
            "TargetLogin"
          ]
        },
        {
          "name": "RouteLogin",
          "pattern": "login",
          "target": [
            "TargetLogin"
          ]
        },
        {
          "name": "RouteHome",
          "pattern": "home",
          "target": [
            "TargetHome"
          ]
        },
        {
          "name": "RouteProfile",
          "pattern": "profile",
          "target": [
            "TargetProfile"
          ]
        },
        {
          "name": "RouteUserManagement",
          "pattern": "userManagement",
          "target": [
            "TargetUserManagement"
          ]
        },
        {
          "name": "RouteUserManagementTab",
          "pattern": "userManagement/tab/{tab}",
          "target": [
            "TargetUserManagement"
          ]
        },
        {
          "name": "RouteUserDetail",
          "pattern": "userManagement/{username}",
          "target": [
            "TargetUserDetail"
          ]
        },
        {
          "name": "RouteSystemManagement",
          "pattern": "systemManagement",
          "target": [
            "TargetSystemManagement"
          ]
        },
        {
          "name": "RouteDataSourceManagement",
          "pattern": "dataSourceManagement",
          "target": [
            "TargetDataSourceManagement"
          ]
        },
        {
          "name": "RouteSchedulerManagement",
          "pattern": "schedulerManagement",
          "target": [
            "TargetSchedulerManagement"
          ]
        },
        {
          "name": "RouteNotifyChannelManagement",
          "pattern": "notifyChannelManagement",
          "target": [
            "TargetNotifyChannelManagement"
          ]
        }
      ],
      "targets": {
        "TargetLogin": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": true,
          "viewName": "Login"
        },
        "TargetHome": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": true,
          "viewName": "Home"
        },
        "TargetProfile": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "Profile"
        },
        "TargetUserManagement": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "UserManagement"
        },
        "TargetUserDetail": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "UserDetail"
        },
        "TargetSystemManagement": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "SystemManagement"
        },
        "TargetDataSourceManagement": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "DataSourceManagement"
        },
        "TargetSchedulerManagement": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "SchedulerManagement"
        },
        "TargetNotifyChannelManagement": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "NotifyChannelManagement"
        }
      }
    }
  }
}